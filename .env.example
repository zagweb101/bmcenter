# ============================================================
# Bayt Almoswer — Environment Template (PRD §6: no secrets in code)
# Copy to .env and fill. NEVER commit real values.
# ============================================================

APP_NAME="BAYT ALMOSWER"
APP_ENV=local
APP_URL=http://localhost
APP_LOCALE=ar
APP_DIRECTION=rtl

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bayt_almoswer
DB_USERNAME=
DB_PASSWORD=

# --- Cache / Queue (Redis) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Object Storage (S3-compatible) ---
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=
S3_REGION=

# --- Payment Gateway (single provider behind Adapter — PRD §18) ---
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# --- ZATCA (keys live in Secrets Vault, NOT here — PRD §16.4) ---
ZATCA_ENV=sandbox
ZATCA_EGS_UNIT_ID=

# --- Multi-tenancy (PRD §12, ADR-003) ---
DEFAULT_ORGANIZATION_ID=
