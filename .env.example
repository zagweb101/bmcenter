# ============================================================
# بيت المصور — متغيرات البيئة (PRD §6: لا تحفظ أسرار في الكود)
# انسخ إلى .env وعدّل بقيمك. لا تحفظ قيمًا فعلية.
# ============================================================

# ========== CORE APPLICATION ==========
APP_NAME="Bayt Almoswer"
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_URL=http://localhost:8000
APP_LOCALE=ar
APP_DIRECTION=rtl

# ========== PORTS ==========
API_PORT=8000
FRONTEND_PORT=3000

# ========== DATABASE (PostgreSQL) ==========
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bayt_almoswer
DB_USERNAME=postgres
DB_PASSWORD=secret

# ========== CACHE & QUEUE (Redis) ==========
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ========== FRONTEND ==========
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NODE_ENV=development

# ========== AUTHENTICATION (Sanctum) ==========
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost
SANCTUM_ENCRYPTION_KEY=
SESSION_DRIVER=cookie

# ========== MAIL ==========
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@baytalmoswer.net
MAIL_FROM_NAME="Bayt Almoswer Academy"

# ========== OBJECT STORAGE (S3-compatible — PRD §21) ==========
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=bayt-almoswer-dev
AWS_ENDPOINT=

# ========== PAYMENT GATEWAY (ADR-005: Adapter pattern — PRD §18) ==========
PAYMENT_GATEWAY=sandbox
PAYMENT_GATEWAY_KEY=pk_test_xxxxxxxxxxxxx
PAYMENT_GATEWAY_SECRET=sk_test_xxxxxxxxxxxxx
PAYMENT_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
PAYMENT_SANDBOX_MODE=true

# ========== ZATCA E-INVOICING (PRD §16 — Keys in Vault, NOT here) ==========
ZATCA_ENV=sandbox
ZATCA_ORGANIZATION_ID=
ZATCA_ORGANIZATION_VAT=
ZATCA_OTP=
ZATCA_USE_SOLUTION_PROVIDER=false
ZATCA_SOLUTION_PROVIDER_ID=

# ========== COMPLIANCE & PRIVACY (PRD §19 — PDPL) ==========
DPO_EMAIL=dpo@baytalmoswer.net
DATA_RETENTION_DAYS=2190
BACKUP_RETENTION_DAYS=90
PDPL_DATA_RESIDENCY_COUNTRY=SA

# ========== MULTI-TENANCY (ADR-003 — PRD §12) ==========
DEFAULT_ORGANIZATION_ID=
ORGANIZATION_ISOLATION_ENFORCED=true

# ========== MONITORING & LOGGING ==========
LOG_CHANNEL=stack
LOG_LEVEL=debug
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1

# ========== EXTERNAL INTEGRATIONS (Deferred: MVP-0B+) ==========
# WhatsApp Business API
WHATSAPP_BUSINESS_API_KEY=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_WEBHOOK_TOKEN=

# ========== LOCAL DEVELOPMENT ONLY ==========
# لا تحفظ كلمات مرور فعلية هنا
ADMIN_EMAIL=admin@baytalmoswer.local
ADMIN_PASSWORD=password
